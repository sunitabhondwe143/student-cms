<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Student Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #F4F7FE;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
    }
    .login-card {
      background: #fff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(112, 144, 176, 0.12);
      width: 100%;
      max-width: 420px;
      text-align: center;
    }
    .logo-box {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 24px;
      margin: 0 auto 20px auto;
    }
    h4 { color: #2B3674; font-weight: 700; }
    .subtext { color: #A3AED0; font-size: 14px; margin-bottom: 30px; }
    .form-control {
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
      background: #fff;
    }
    .btn-signin {
      background: #6366F1;
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 12px;
      font-weight: 600;
      width: 100%;
      transition: background 0.2s;
    }
    .btn-signin:hover { background: #4F46E5; color: #fff; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h4>Welcome Back</h4>
    <p class="subtext">Student Management System</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger py-2" role="alert"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="mb-3 text-start">
        <label class="form-label fw-semibold" style="color:#2B3674; font-size:13px;">Email</label>
        <input type="text" name="email" class="form-control" placeholder="Enter your email" required>
      </div>
      <div class="mb-4 text-start">
        <label class="form-label fw-semibold" style="color:#2B3674; font-size:13px;">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-signin">Sign In</button>
    </form>
  </div>
</body>
</html>
